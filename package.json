    "@types/chrome": "^0.0.287",
    "@types/webextension-polyfill": "^0.12.1",
    "eslint": "^10.6.0",
    "fake-indexeddb": "^6.0.1",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.62.1",
